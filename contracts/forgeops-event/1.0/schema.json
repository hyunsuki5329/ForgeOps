{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgeops.local/contracts/forgeops-event/1.0/schema.json",
  "title": "ForgeOps Durable Event Wrapper 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "event_id",
    "task_id",
    "run_id",
    "correlation_id",
    "stream_id",
    "stream_seq",
    "recorded_at",
    "accepted_revision",
    "canonical_event",
    "provenance"
  ],
  "properties": {
    "schema_id": {
      "const": "forgeops.event"
    },
    "schema_version": {
      "const": "1.0"
    },
    "event_id": {
      "$ref": "#/$defs/identifier"
    },
    "task_id": {
      "$ref": "#/$defs/identifier"
    },
    "run_id": {
      "$ref": "#/$defs/identifier"
    },
    "correlation_id": {
      "$ref": "#/$defs/identifier"
    },
    "stream_id": {
      "$ref": "#/$defs/identifier"
    },
    "stream_seq": {
      "type": "integer",
      "minimum": 1
    },
    "recorded_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "accepted_revision": {
      "type": "integer",
      "minimum": 0
    },
    "canonical_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seq",
        "task_id",
        "correlation_id",
        "actor",
        "phase",
        "attempt",
        "severity",
        "code",
        "action",
        "evidence_refs"
      ],
      "properties": {
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "task_id": {
          "$ref": "#/$defs/identifier"
        },
        "correlation_id": {
          "$ref": "#/$defs/identifier"
        },
        "actor": {
          "enum": [
            "main",
            "part",
            "work"
          ]
        },
        "phase": {
          "enum": [
            "NORMALIZE",
            "DISCOVER",
            "EXECUTE",
            "VERIFY",
            "DECIDE",
            "GATE"
          ]
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "severity": {
          "enum": [
            "INFO",
            "WARNING",
            "STANDARD",
            "CRITICAL"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "action": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_reference"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_ref",
        "content_sha256",
        "recorder_id"
      ],
      "properties": {
        "source_kind": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "source_ref": {
          "$ref": "#/$defs/identifier"
        },
        "content_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "recorder_id": {
          "$ref": "#/$defs/identifier"
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_reference": {
      "type": "string",
      "minLength": 6,
      "maxLength": 128,
      "pattern": "^EVID-[A-Za-z0-9][A-Za-z0-9._:-]{0,122}$"
    }
  }
}
